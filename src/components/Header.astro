---
import { Image } from 'astro:assets';
import logoAees from '../assets/cropped-logo-aees-2024.jpg';
---

<header class="w-full bg-white/80 backdrop-blur-md border-b border-gray-100 sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-2 group">
          <!-- Nouveau logo dynamique -->
          <Image 
            src={logoAees} 
            alt="Logo AEES" 
            class="h-10 w-auto object-contain group-hover:scale-105 transition-transform"
          />
          <span class="font-extrabold text-xl tracking-tight bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent">
            Europe<span class="text-cyan-500 font-medium">Sociale</span>
          </span>
        </a>
      </div>

      <nav class="hidden md:flex items-center gap-1">
        <a 
          href="/" 
          class="px-4 py-2 text-sm font-medium text-gray-600 rounded-lg hover:text-cyan-600 hover:bg-gray-50/80 transition-all duration-200"
        >
          Accueil
        </a>
        <a 
          href="/histoire" 
          class="px-4 py-2 text-sm font-medium text-gray-600 rounded-lg hover:text-cyan-600 hover:bg-gray-50/80 transition-all duration-200"
        >
          Notre Histoire
        </a>
        <a 
          href="/veille" 
          class="px-4 py-2 text-sm font-medium text-gray-600 rounded-lg hover:text-cyan-600 hover:bg-gray-50/80 transition-all duration-200"
        >
          Veille Réglementaire
        </a>
      </nav>

      <div class="hidden md:flex items-center">
        <a 
          href="/contact" 
          class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-gray-900 rounded-xl hover:bg-cyan-600 shadow-sm hover:shadow transition-all duration-200 hover:-translate-y-0.5"
        >
          Nous contacter
        </a>
      </div>

    </div>
  </div>
</header>