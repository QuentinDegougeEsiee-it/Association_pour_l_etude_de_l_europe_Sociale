---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- En-tête de la page Admin (Largeur fixée à max-w-2xl) -->
  <section class="bg-gray-900 text-white py-12 border-b border-gray-800">
    <div class="w-full max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-flex items-center justify-center p-3 bg-cyan-500/20 text-cyan-400 rounded-full mb-4">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h1 class="text-3xl font-black tracking-tight mb-4">Espace Administration</h1>
      <p class="text-lg text-gray-400">Ajoutez une nouvelle publication à la page Actualités & Veille.</p>
    </div>
  </section>

  <!-- Formulaire d'ajout (Largeur fixée à max-w-2xl également) -->
  <section class="py-16 bg-gray-50 flex-grow">
    <div class="w-full max-w-2xl mx-auto px-4 sm:px-6">
      
      <div class="bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-gray-100">
        
        <form id="adminForm" class="space-y-6">
          
          <!-- Titre -->
          <div>
            <label for="titre" class="block text-sm font-bold text-gray-700 mb-2">Titre de l'article / document</label>
            <input 
              type="text" 
              id="titre" 
              name="titre" 
              required 
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all" 
              placeholder="Ex: Nouvelle directive européenne..."
            >
          </div>

          <!-- Description -->
          <div>
            <label for="description" class="block text-sm font-bold text-gray-700 mb-2">Courte description</label>
            <textarea 
              id="description" 
              name="description" 
              rows="3" 
              required 
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all resize-y" 
              placeholder="Résumé du texte ou de l'analyse..."
            ></textarea>
          </div>

          <!-- Ligne 2 colonnes : Date et Source -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="date" class="block text-sm font-bold text-gray-700 mb-2">Date de publication</label>
              <input 
                type="date" 
                id="date" 
                name="date" 
                required 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all text-gray-600"
              >
            </div>
            
            <div>
              <label for="source" class="block text-sm font-bold text-gray-700 mb-2">Site d'origine</label>
              <select 
                id="source" 
                name="source" 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all cursor-pointer"
              >
                <option value="Think Tank CRAPS">Think Tank CRAPS</option>
                <option value="Commission Européenne">Commission Européenne</option>
                <option value="EIOPA">EIOPA</option>
                <option value="AEIP">AEIP</option>
                <option value="AUTRE">Autre source...</option>
              </select>
            </div>
          </div>

          <!-- Ligne 2 colonnes : Lien et Format -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="lien" class="block text-sm font-bold text-gray-700 mb-2">Lien URL (Source)</label>
              <input 
                type="url" 
                id="lien" 
                name="lien" 
                required 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all" 
                placeholder="https://..."
              >
            </div>
            
            <div>
              <label for="format" class="block text-sm font-bold text-gray-700 mb-2">Format de la ressource</label>
              <select 
                id="format" 
                name="format" 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all cursor-pointer"
              >
                <option value="Article">Article / Page Web</option>
                <option value="PDF">Document PDF</option>
              </select>
            </div>
          </div>

          <!-- Bouton Publier -->
          <div class="pt-6 border-t border-gray-100 mt-8">
            <button 
              type="submit" 
              class="w-full py-4 px-6 text-white bg-cyan-600 hover:bg-cyan-700 font-bold rounded-xl shadow-sm transition-colors flex justify-center items-center gap-2 group"
            >
              <svg class="w-5 h-5 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
              </svg>
              Publier dans les actualités
            </button>
          </div>

        </form>

      </div>
    </div>
  </section>
</Layout>

<!-- Script Client pour préremplir la date -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Gérer la date automatique
    const dateInput = document.getElementById('date') as HTMLInputElement;
    if (dateInput) {
      const today = new Date();
      // Formatage requis par HTML5 : YYYY-MM-DD
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      
      dateInput.value = `${yyyy}-${mm}-${dd}`;
    }

    // 2. Gérer la soumission du formulaire
    const form = document.getElementById('adminForm') as HTMLFormElement;
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault(); // Empêche le rechargement de la page
        alert("L'interface est prête ! Une fois la base de données Supabase connectée, ce bouton enverra les données pour mettre à jour la page Actualités.");
      });
    }
  });
</script>