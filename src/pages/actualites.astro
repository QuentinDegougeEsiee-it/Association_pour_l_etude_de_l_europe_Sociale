---
import Layout from '../layouts/Layout.astro';

const articles = [
  {
    titre: "Nouvelle directive sur les droits sociaux fondamentaux",
    source: "Commission Européenne",
    type: "PDF",
    date: "25 Juin 2026",
    dateISO: "2026-06-25", 
    description: "Publication officielle détaillant les nouvelles orientations de la Commission pour la protection des travailleurs transfrontaliers.",
    lien: "https://op.europa.eu/fr/web/general-publications/publications",
    couleurBadge: "bg-blue-100 text-blue-800"
  },
  {
    titre: "Rapport sur les pensions de retraite en Europe",
    source: "EIOPA",
    type: "Article",
    date: "18 Juin 2026",
    dateISO: "2026-06-18",
    description: "Analyse technique et recommandations de l'EIOPA concernant l'évolution des régimes de retraite face à l'inflation.",
    lien: "https://eiopa.europa.eu/",
    couleurBadge: "bg-purple-100 text-purple-800"
  },
  {
    titre: "L'impact du dialogue social sur la compétitivité",
    source: "Think Tank CRAPS",
    type: "Article", // Changé de Analyse à Article pour correspondre aux filtres
    date: "10 Juin 2026",
    dateISO: "2026-06-10",
    description: "Une réflexion de fond sur la manière dont le syndicalisme moderne peut s'intégrer dans les nouveaux modèles d'entreprise.",
    lien: "https://www.thinktankcraps.fr",
    couleurBadge: "bg-orange-100 text-orange-800"
  },
  {
    titre: "Position paper : Les fonds de pension paritaires",
    source: "AEIP",
    type: "PDF",
    date: "02 Juin 2026",
    dateISO: "2026-06-02",
    description: "Document de position de l'AEIP visant à défendre le modèle paritaire dans la révision de la réglementation européenne.",
    lien: "#",
    couleurBadge: "bg-emerald-100 text-emerald-800"
  }
];
---

<Layout>
  <!-- En-tête de la page -->
  <section class="bg-gray-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-black tracking-tight mb-4">Actualités & Veille Réglementaire</h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Retrouvez les dernières publications, analyses et textes officiels impactant la protection sociale et le syndicalisme en Europe.
      </p>
    </div>
  </section>

  <!-- Section de contenu -->
  <section class="py-12 bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Bouton d'ajout admin (caché sur mobile, visible sur desktop) -->
      <div class="hidden md:flex items-center pb-3 justify-end">
        <a 
          href="/admin" 
          class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-cyan-500 rounded-xl hover:bg-cyan-600 shadow-sm hover:shadow transition-all duration-200 hover:-translate-y-0.5"
        >
          Ajouter une publication
        </a>
      </div>
      
      <!-- Contrôles : Recherche, Filtres et Tri -->
      <div class="mb-10 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
        
        <div class="flex flex-col md:flex-row gap-4 justify-between items-center">
          
          <!-- Ligne du haut : Recherche principale -->
          <div class="relative w-full">
            <svg class="w-5 h-5 text-gray-400 absolute left-3 top-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input 
              type="text" 
              id="searchInput" 
              placeholder="Rechercher par titre..." 
              class="w-full pl-10 pr-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all"
            >
          </div>

        </div>

        <!-- Ligne du bas : Filtres et Tri -->
        <div class="flex flex-col md:flex-row gap-4 items-center justify-between mt-4 pt-4 border-t border-gray-100">
          
          <!-- Filtres (Format et Source) -->
          <div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto">
            
            <div class="flex items-center gap-2">
              <label for="formatFilter" class="text-sm font-medium text-gray-600 whitespace-nowrap">Format :</label>
              <select id="formatFilter" class="w-full sm:w-auto px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-cyan-500 outline-none cursor-pointer transition-all text-sm">
                <option value="all">Tous les formats</option>
                <option value="article">Article</option>
                <option value="pdf">PDF</option>
              </select>
            </div>

            <div class="flex items-center gap-2">
              <label for="sourceFilter" class="text-sm font-medium text-gray-600 whitespace-nowrap">Source :</label>
              <select id="sourceFilter" class="w-full sm:w-auto px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-cyan-500 outline-none cursor-pointer transition-all text-sm">
                <option value="all">Toutes les sources</option>
                <option value="think tank craps">Think Tank CRAPS</option>
                <option value="commission européenne">Commission Européenne</option>
                <option value="eiopa">EIOPA</option>
                <option value="aeip">AEIP</option>
                <option value="autre">Autre</option>
              </select>
            </div>
            
          </div>

          <!-- Menu de tri (Date) -->
          <div class="flex items-center gap-2 w-full md:w-auto">
            <label for="sortSelect" class="text-sm font-medium text-gray-600 whitespace-nowrap">Trier par :</label>
            <select 
              id="sortSelect" 
              class="w-full md:w-auto px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-cyan-500 outline-none cursor-pointer transition-all text-sm"
            >
              <option value="desc">Plus récent</option>
              <option value="asc">Plus ancien</option>
            </select>
          </div>

        </div>

      </div>

      <!-- Grille des articles/PDF -->
      <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
        {articles.map((article) => (
          <article 
            class="article-card bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group"
            data-title={article.titre.toLowerCase()}
            data-date={article.dateISO}
            data-format={article.type.toLowerCase()}
            data-source={article.source.toLowerCase()}
          >
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class={`px-3 py-1 text-xs font-bold uppercase tracking-wider rounded-full ${article.couleurBadge}`}>
                  {article.source}
                </span>
                <span class="text-sm text-gray-500 font-medium flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  {article.date}
                </span>
              </div>
              
              <h2 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-cyan-600 transition-colors">
                {article.titre}
              </h2>
              
              <p class="text-gray-600 mb-6 line-clamp-3">
                {article.description}
              </p>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <span class="text-sm font-semibold text-gray-400 flex items-center gap-1">
                {article.type === "PDF" ? (
                  <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                ) : (
                  <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H15" />
                  </svg>
                )}
                Format : {article.type}
              </span>
              
              <a href={article.lien} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold text-cyan-700 bg-cyan-50 rounded-lg hover:bg-cyan-600 hover:text-white transition-colors">
                {article.type === "PDF" ? "Télécharger le PDF" : "Lire la suite"}
                <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
</Layout>

<!-- Script Client pour gérer la recherche, les filtres et le tri -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const sortSelect = document.getElementById('sortSelect') as HTMLSelectElement;
    const formatFilter = document.getElementById('formatFilter') as HTMLSelectElement;
    const sourceFilter = document.getElementById('sourceFilter') as HTMLSelectElement;
    const grid = document.getElementById('articles-grid') as HTMLElement;    
    
    if (!searchInput || !sortSelect || !formatFilter || !sourceFilter || !grid) return;

    const cards = Array.from(grid.getElementsByClassName('article-card')) as HTMLElement[];

    function updateView() {
      const searchTerm = searchInput.value.toLowerCase().trim();
      const sortOrder = sortSelect.value;
      const formatValue = formatFilter.value;
      const sourceValue = sourceFilter.value;

      // 1. Gérer les filtres (Recherche textuelle + Format + Source)
      let visibleCards = cards.filter(card => {
        const title = card.getAttribute('data-title') || '';
        const format = card.getAttribute('data-format') || '';
        const source = card.getAttribute('data-source') || '';

        const matchesSearch = title.includes(searchTerm);
        const matchesFormat = formatValue === 'all' || format === formatValue;
        const matchesSource = sourceValue === 'all' || source === sourceValue;

        const isVisible = matchesSearch && matchesFormat && matchesSource;
        
        card.style.display = isVisible ? 'flex' : 'none';
        return isVisible;
      });

      // 2. Gérer le tri sur les cartes visibles
      visibleCards.sort((a, b) => {
        const dateA = new Date(a.getAttribute('data-date') || '').getTime();
        const dateB = new Date(b.getAttribute('data-date') || '').getTime();
        
        return sortOrder === 'desc' ? dateB - dateA : dateA - dateB;
      });

      // 3. Réorganiser l'ordre dans le HTML
      visibleCards.forEach(card => grid.appendChild(card));
    }

    // Écouter les événements
    searchInput.addEventListener('input', updateView);
    sortSelect.addEventListener('change', updateView);
    formatFilter.addEventListener('change', updateView);
    sourceFilter.addEventListener('change', updateView);

    // Lancer une première fois au chargement
    updateView();
  });
</script>