---
import Layout from '../layouts/Layout.astro';
import testPP from '../assets/test_PP.avif';
---

<Layout>
  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-20 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-gray-900 uppercase mb-6">
        Association pour l'étude de <br/>
        <span class="text-transparent bg-clip-text bg-linear-to-r from-cyan-500 to-blue-600">l'Europe Sociale</span>
      </h1>
      <p class="max-w-2xl mx-auto text-xl text-gray-900 mb-10">
        Notre mission : compiler l'information et décrypter la réglementation européenne qui impacte la protection sociale et le syndicalisme afin de <span class="font-bold text-blue-500">Vous Accompagner</span>.
      </p>
      <div class="flex flex-col items-center justify-center gap-4">
        <a href="/actualites" class="px-8 py-3 text-base font-semibold text-white bg-cyan-500 rounded-xl hover:bg-cyan-700 transition-colors shadow-sm text-center">
          Consulter les dernières actualités <br/> du droit social européen
        </a>
        <a href="/contact" class="px-8 py-3 text-base font-semibold text-gray-700 bg-gray-200 rounded-xl hover:bg-gray-300 transition-colors">
          Nous contacter
        </a>
      </div>
    </div>
    
    <!-- Éléments de décoration d'arrière-plan -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full overflow-hidden -z-10 opacity-30 pointer-events-none">
      <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-cyan-200 rounded-full mix-blend-multiply filter blur-3xl opacity-70"></div>
      <div class="absolute top-[20%] right-[-10%] w-96 h-96 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-70"></div>
    </div>
  </section>

  <!-- Section Nos Missions -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900">Nos Actions</h2>
        <p class="mt-4 text-lg text-gray-600">Donner de la visibilité aux enjeux sociaux européens.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Carte 1 -->
        <article class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="h-12 w-12 bg-cyan-100 text-cyan-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H15" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Actualités</h3>
          <p class="text-gray-600">
            Suivi des décisions de la Commission européenne et diffusion d'articles pour comprendre l'évolution du droit social.
          </p>
        </article>

        <!-- Carte 2 -->
        <article class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="h-12 w-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Formation & Conférences</h3>
          <p class="text-gray-600">
            Organisation d'événements et de formations pour les acteurs de la protection sociale.
          </p>
        </article>

        <!-- Carte 3 -->
        <article class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="h-12 w-12 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Mise en réseau</h3>
          <p class="text-gray-600">
            Centralisation des ressources, liens vers d'autres sites spécialisés et promotion des travaux du milieu syndical européen.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Section Sources et Références -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Nos Sources </h2>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-70 grayscale hover:grayscale-0 transition-all duration-300">
        <!-- Remplacer les div par de vraies balises <img> quand tu auras les logos -->
        <a href="https://www.thinktankcraps.fr" target="_blank" rel="noopener noreferrer" class="text-lg font-bold hover:text-cyan-600">Think Tank CRAPS</a>
        <a href="https://op.europa.eu/fr/web/general-publications/publications" target="_blank" rel="noopener noreferrer" class="text-lg font-bold hover:text-cyan-600">Commission Européenne</a>
        <a href="https://eiopa.europa.eu/" target="_blank" rel="noopener noreferrer" class="text-lg font-bold hover:text-cyan-600">EIOPA</a>
        <a href="https://aeip.net" target="_blank" rel="noopener noreferrer" class="text-lg font-bold hover:text-cyan-600">AEIP</a>
      </div>
    </div>
  </section>

  
</Layout>