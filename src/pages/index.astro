---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center space-y-4">
      <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-gray-900 uppercase">
        Association pour l'étude de l'Europe <span class="text-cyan-500">Sociale</span>
      </h1>
      <p class="max-w-2xl mx-auto text-lg text-gray-500">
        Veille réglementaire, analyses juridiques et actualités du syndicalisme européen.
      </p>
    </div>
  </main>
</Layout>