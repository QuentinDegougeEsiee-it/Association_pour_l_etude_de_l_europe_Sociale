---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- En-tête de la page -->
  <section class="bg-gray-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-black tracking-tight mb-4">Contactez-nous</h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Une question, un besoin de formation ou une proposition d'intervention ? L'équipe de l'AEES est à votre écoute.
      </p>
    </div>
  </section>

  <!-- Section principale -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Colonne de gauche : Informations de contact -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Discutons ensemble</h2>
          <p class="text-gray-600 mb-8 text-lg">
            Que vous représentiez un syndicat, une entreprise ou que vous soyez un professionnel de la protection sociale, nous pouvons vous accompagner pour décrypter les enjeux réglementaires européens.
          </p>
          
          <div class="space-y-8">
            <!-- Bloc Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-cyan-100 text-cyan-600 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900">Par e-mail</h3>
                <p class="text-gray-600 mb-2">Notre équipe vous répondra dans les plus brefs délais.</p>
                <a href="mailto:aees.20101992@gmail.com" class="text-cyan-600 font-bold hover:underline text-lg">
                  aees.20101992@gmail.com
                </a>
              </div>
            </div>

            <!-- Bloc Équipe -->
            <div class="flex items-start gap-4 pt-8 border-t border-gray-200">
              <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900">Le Bureau</h3>
                <ul class="text-gray-600 space-y-1 mt-1">
                  <li><span class="font-semibold text-gray-800">Menouar</span> — Président</li>
                  <li><span class="font-semibold text-gray-800">Ludovic</span> — Trésorier</li>
                  <li><span class="font-semibold text-gray-800">Audrai</span> — Secrétaire</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Colonne de droite : Formulaire de contact -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Envoyez-nous un message</h3>
          
          <form action="#" method="POST" class="space-y-6">
            <!-- Champ Nom -->
            <div>
              <label for="nom" class="block text-sm font-medium text-gray-700 mb-2">Nom complet / Organisation</label>
              <input 
                type="text" 
                id="nom" 
                name="nom" 
                required 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all" 
                placeholder="Ex: Jean Dupont ou Syndicat XYZ"
              >
            </div>

            <!-- Champ Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Adresse e-mail</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all" 
                placeholder="jean.dupont@exemple.com"
              >
            </div>

            <!-- Champ Sujet -->
            <div>
              <label for="sujet" class="block text-sm font-medium text-gray-700 mb-2">Sujet de votre demande</label>
              <select 
                id="sujet" 
                name="sujet" 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all"
              >
                <option value="formation">Demande de formation</option>
                <option value="conference">Organisation d'une conférence</option>
                <option value="partenariat">Proposition de partenariat</option>
                <option value="autre">Autre question</option>
              </select>
            </div>

            <!-- Champ Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Votre message</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                required 
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all resize-y" 
                placeholder="Expliquez-nous votre besoin..."
              ></textarea>
            </div>

            <!-- Bouton de soumission -->
            <button 
              type="submit" 
              class="w-full py-3 px-6 text-white bg-cyan-600 hover:bg-cyan-700 font-bold rounded-xl shadow-sm transition-colors flex justify-center items-center gap-2 group"
            >
              Envoyer le message
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </form>

        </div>

      </div>
    </div>
  </section>
</Layout>